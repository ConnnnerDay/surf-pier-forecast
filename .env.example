# Copy this file to .env and fill in your values.
# Load it before starting the app: export $(grep -v '^#' .env | xargs)
# Or use python-dotenv: pip install python-dotenv

# Required in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Port the dev server listens on (default: 5757)
# PORT=5757

# Set to 1 to enable Flask debug mode (never use in production)
# FLASK_DEBUG=0
